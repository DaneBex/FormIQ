# Copy this file to .env.local and fill in your values.
# .env.local is gitignored and never committed.

# Anthropic — AI coaching feedback after each set
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Supabase — auth and session metadata sync
# Create a project at https://supabase.com, then find these under Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=

# RevenueCat — subscription paywall
# Find your iOS key under API Keys in your RevenueCat dashboard
REVENUECAT_IOS_API_KEY=
